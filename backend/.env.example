# =============================================================
# Variables de entorno del BACKEND (Node.js/Express)
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# =============================================================

# Puerto en que escucha el servidor
PORT=4000

# Cadena de conexión a MongoDB Atlas
DATABASE_URL=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/<nombre_db>?retryWrites=true&w=majority

# Clave secreta para firmar tokens JWT (genera con: openssl rand -base64 32)
JWT_SECRET=<string_aleatorio_seguro_minimo_32_caracteres>

# Clave para registrar administradores (genera con: openssl rand -base64 16)
ADMIN_REGISTER_KEY=<string_aleatorio_seguro>

# Origen permitido por CORS (URL del frontend en producción)
# Desarrollo: http://localhost:5173
# Producción: https://tu-frontend.com
CORS_ORIGIN=http://localhost:5173
